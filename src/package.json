{
  "name": "smart-home-database-sync",
  "version": "1.0.0",
  "private": true,
  "description": "Sincroniza mensagens MQTT de dispositivos com a API Smart Home.",
  "main": "app/app.js",
  "scripts": {
    "start": "node app/app.js",
    "test": "node --test ../test/unit/*.test.js ../test/integration/*.test.js",
    "test:unit": "node --test ../test/unit/*.test.js",
    "test:integration": "node --test ../test/integration/*.test.js",
    "lint": "eslint ../src/app ../test ../scripts",
    "format": "prettier --write ../src ../test ../scripts ../.github ../README.md",
    "format:check": "prettier --check ../src ../test ../scripts ../.github ../README.md"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "axios": "^1.8.3",
    "mqtt": "^5.10.4",
    "pino": "^9.5.0"
  },
  "devDependencies": {
    "eslint": "^10.7.0",
    "pino-pretty": "^9.1.1",
    "prettier": "^3.9.5"
  }
}
